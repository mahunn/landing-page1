ADMIN_ID=Admin
ADMIN_PASSWORD=AdminMahin123
SESSION_SECRET=#Vpolp9Q995

# Vercel only: create a Blob store (Dashboard → Storage → Blob) and connect it to this project.
# Without this token, saving product/FAQ/orders on Vercel fails (server filesystem is read-only).
BLOB_READ_WRITE_TOKEN=

# If Blob uploads/reads fail on a "Private" store, set: BLOB_JSON_ACCESS=private
# BLOB_JSON_ACCESS=

# ── Meta Ads Manager ────────────────────────────────────────────────────────
# Long-lived System User token from Meta Business Settings → System Users
META_ACCESS_TOKEN=

# Your Ad Account ID — get it from Meta Ads Manager (act_ prefix added automatically if missing)
META_AD_ACCOUNT_ID=

# Facebook Pixel ID — find it in Events Manager → your Pixel → Settings
# This is a ~15-digit number (different from the Ad Account ID)
NEXT_PUBLIC_META_PIXEL_ID=

# Optional: your site's public URL (used in CAPI event_source_url)
NEXT_PUBLIC_SITE_URL=

# Meta Conversions API Test Event Code (from Events Manager → Test Events)
# META_TEST_EVENT_CODE=
